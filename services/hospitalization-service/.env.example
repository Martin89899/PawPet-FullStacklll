# Configuración del Servidor
NODE_ENV=development
PORT=3005

# Configuración de Base de Datos
DB_HOST=localhost
DB_PORT=5436
DB_NAME=pawpet_hospitalization
DB_USER=pawpet_user
DB_PASSWORD=pawpet_password

# Configuración de RabbitMQ
RABBITMQ_URL=amqp://pawpet_user:pawpet_password@localhost:5672/pawpet_vhost

# Configuración de Autenticación
AUTH_SERVICE_URL=http://localhost:3001

# Configuración de CORS
CORS_ORIGIN=http://localhost:3101,http://localhost:3102,http://localhost:3103

# Configuración de Hospitalización
MAX_PATIENTS_PER_ROOM=4
DEFAULT_MONITORING_INTERVAL_MINUTES=30
VITAL_SIGNS_ALERT_THRESHOLD_TEMPERATURE=39.5
VITAL_SIGNS_ALERT_THRESHOLD_HEART_RATE=120

# Configuración de JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Configuración de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configuración de Logging
LOG_LEVEL=info
