# Configuración del Servidor
NODE_ENV=development
PORT=3002

# Configuración de Base de Datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pawpet_appointments
DB_USER=pawpet_user
DB_PASSWORD=pawpet_password

# Configuración de RabbitMQ
RABBITMQ_URL=amqp://pawpet_user:pawpet_password@localhost:5672/pawpet_vhost

# Configuración de Autenticación
AUTH_SERVICE_URL=http://localhost:3001

# Configuración de CORS
CORS_ORIGIN=http://localhost:3101,http://localhost:3102,http://localhost:3103

# Configuración de Citas
APPOINTMENT_DURATION_MINUTES=30
MAX_APPOINTMENTS_PER_DAY=50

# Configuración de JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Configuración de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Configuración de WebSocket
WEBSOCKET_CORS_ORIGIN=http://localhost:3101,http://localhost:3102,http://localhost:3103

# Configuración de Recordatorios
REMINDER_ADVANCE_HOURS=24
REMINDER_ENABLED=true

# Configuración de Logging
LOG_LEVEL=info
